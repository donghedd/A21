### 极简代码实现思路（符合你喜欢的简单 for 循环风格）

你可以参考这个逻辑来扩展你的 `dataset.py`：

```python
import json
import os

# 模拟一个 LLM 调用函数
def ask_llm_to_generate_question(context):
    prompt = f"请根据以下内容出一个专业问题，并给出简短答案：\n{context}"
    # 这里调用你的 LLM API (如 OpenAI, Gemini, Claude 等)
    # 返回格式示例: {"question": "...", "answer": "..."}
    return {"question": "模拟问题", "answer": "模拟答案"}

def build_synthetic_dataset(file_list, chunk_size=500):
    dataset = {
        "dataset_name": "船舶维修自动化评测集",
        "samples": []
    }
    
    # 使用你最喜欢的简单 for 循环
    for i in range(len(file_list)):
        file_path = file_list[i]
        with open(file_path, 'r', encoding='utf-8') as f:
            content = f.read()
            
        # 简单切分 (实际建议用你的 RAG 切分逻辑)
        chunks = [content[i:i+chunk_size] for i in range(0, len(content), chunk_size)]
        
        for j in range(len(chunks)):
            chunk_text = chunks[j]
            # 调用 LLM 生成问题
            res = ask_llm_to_generate_question(chunk_text)
            
            # 自动构建符合你框架的 sample
            sample = {
                "question": res['question'],
                "gold_results": [
                    {
                        "file_name": os.path.basename(file_path),
                        "chunk_index": j,  # 自动记录索引，无需人工！
                        "answer": res['answer']
                    }
                ]
            }
            dataset["samples"].append(sample)
            
    return dataset

